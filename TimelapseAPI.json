    "/jobs/{job_id}/download": {
      "get": {
        "tags": [
          "jobs"
        ],
        "summary": "Download Video",
        "description": "Stream the rendered MP4 directly from the NAS mount.\n\nThe worker writes a copy to {synology_path}/video/{site}_{job_short}.mp4\nafter each NAS/Synology job. Serving from disk via FileResponse uses\nsendfile() and bypasses the urllib3+MinIO chunked-stream path that\ncapped throughput at ~3 MB/s on multi-GB videos.",
        "operationId": "download_video_jobs__job_id__download_get",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Job Id"
            }
