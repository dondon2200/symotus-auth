          },
          "reference": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Reference"
          }
        },
        "type": "object",
        "required": [
          "images",
          "callback_url"
        ],
        "title": "Body_create_job_jobs_post"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
