    "/jobs/nas": {
      "post": {
        "tags": [
          "jobs"
        ],
        "summary": "Create timelapse from NAS images / 從 NAS 圖片建立縮時影片",
        "description": "Create a timelapse video from images stored on the NAS.\n\n從 NAS 上儲存的圖片建立縮時影片。\n\n**Processing options / 處理選項:**\n- No toggles = Raw video (all images, no processing) / 不開啟選項 = 原始影片\n- rain_fog + darkness = Filtered (remove bad images) / 過濾（移除不良圖片）\n- + image_recovery = Enhanced (recover bad images via AI) / 增強（AI 修復不良圖片）\n- + stabilization = Stabilized (smooth 60fps) / 穩定（平滑 60fps）",
        "operationId": "create_nas_job_jobs_nas_post",
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Api Key"
            }
          },
          {
            "name": "x-api-key",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Api-Key"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NasJobCreateRequest"
              },
              "examples": {
                "raw_video": {
                  "summary": "1. Raw video / 原始影片",
                  "description": "No processing, all images to video. Fastest. 不做任何處理，所有圖片直接生成影片。最快。",
                  "value": {
                    "nas_path": "台電運維_完整",
                    "callback_url": "https://your-server.com/callback",
                    "fps": 30
                  }
                },
                "filtered": {
                  "summary": "2. Filtered / 過濾影片",
                  "description": "Remove rain/fog/dark images. ~26 min for 15K images. 移除雨天/霧氣/過暗圖片。15K 張約 26 分鐘。",
                  "value": {
                    "nas_path": "台電運維_完整",
                    "callback_url": "https://your-server.com/callback",
                    "fps": 30,
                    "rain_fog_detection": true,
                    "darkness_detection": true
                  }
                },
                "enhanced": {
                  "summary": "3. Enhanced / 增強影片",
                  "description": "Detect + recover bad images via AI fusion. ~33 min for 15K images. 偵測 + AI 融合修復不良圖片。15K 張約 33 分鐘。",
                  "value": {
                    "nas_path": "台電運維_完整",
                    "callback_url": "https://your-server.com/callback",
                    "fps": 30,
                    "rain_fog_detection": true,
                    "darkness_detection": true,
                    "image_recovery": true
                  }
                },
                "stabilized": {
                  "summary": "4. Stabilized / 穩定影片",
                  "description": "All processing + smooth 60fps motion interpolation. ~65 min for 15K images. 完整處理 + 平滑 60fps 動態補間。15K 張約 65 分鐘。",
                  "value": {
                    "nas_path": "台電運維_完整",
                    "callback_url": "https://your-server.com/callback",
                    "fps": 30,
                    "rain_fog_detection": true,
                    "darkness_detection": true,
                    "image_recovery": true,
                    "stabilization": true
                  }
                },
                "quick_test": {
                  "summary": "5. Quick test / 快速測試",
                  "description": "Test with 100 images only. 僅使用 100 張圖片測試。",
                  "value": {
                    "nas_path": "台電運維_完整",
                    "callback_url": "https://your-server.com/callback",
                    "fps": 30,
                    "max_images": 100,
                    "rain_fog_detection": true,
                    "darkness_detection": true
                  }
                },
                "rain_only": {
                  "summary": "6. Rain/fog only / 僅偵測雨霧",
                  "description": "Only detect rain/fog, no darkness check. 僅偵測雨滴/霧氣，不檢查亮度。",
                  "value": {
                    "nas_path": "時代海德_完整",
                    "callback_url": "https://your-server.com/callback",
                    "fps": 30,
                    "rain_fog_detection": true
                  }
                },
                "darkness_only": {
                  "summary": "7. Darkness only / 僅偵測亮度",
                  "description": "Only remove too dark/bright images. 僅移除過暗/過亮圖片。",
                  "value": {
                    "nas_path": "時代海德_完整",
                    "callback_url": "https://your-server.com/callback",
                    "fps": 30,
                    "darkness_detection": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobCreateResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
