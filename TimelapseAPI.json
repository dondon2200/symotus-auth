          "job_id",
          "status",
          "image_count",
          "fps",
          "resolution",
          "created_at"
        ],
        "title": "JobStatusResponse"
      },
      "NasJobCreateRequest": {
        "properties": {
          "nas_path": {
            "type": "string",
            "title": "Nas Path",
            "description": "Folder path on NAS containing the images. NAS 上包含圖片的資料夾路徑。",
            "examples": [
              "台電運維_完整",
              "時代海德_完整"
            ]
          },
          "callback_url": {
            "type": "string",
            "title": "Callback Url",
            "description": "URL to receive job completion notification. 任務完成時接收通知的網址。"
          },
          "fps": {
            "type": "integer",
            "maximum": 60,
            "minimum": 1,
            "title": "Fps",
            "description": "Video frame rate (frames per second). 影片幀率（每秒幀數）。",
            "default": 30
          },
          "resolution": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Resolution",
            "description": "Video resolution. Default: 3840x2160 (4K). 影片解析度。預設：3840x2160（4K）。",
            "examples": [
              "3840x2160",
              "1920x1080"
            ]
          },
          "reference": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Reference",
            "description": "Reference image filename for color correction. Auto-selected if not set. 色彩校正的參考圖片檔名。未設定則自動選擇。"
          },
          "start_date": {
            "anyOf": [
              {
                "type": "string",
                "format": "date"
              },
              {
                "type": "null"
              }
            ],
            "title": "Start Date",
            "description": "Only include images after this date (requires date in filename). 僅包含此日期之後的圖片（需要檔名中包含日期）。"
          },
          "end_date": {
            "anyOf": [
              {
                "type": "string",
                "format": "date"
              },
              {
                "type": "null"
              }
            ],
            "title": "End Date",
            "description": "Only include images before this date (requires date in filename). 僅包含此日期之前的圖片（需要檔名中包含日期）。"
          },
          "max_images": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Max Images",
            "description": "Limit to first N images. Useful for quick tests. 限制前 N 張圖片。適用於快速測試。",
            "examples": [100, 500, 1000]
          },
          "rain_fog_detection": {
            "type": "boolean",
            "title": "Rain Fog Detection",
            "description": "Enable AI rain/fog/water-drop detection (CLIP model). Removes images with rain drops, fog, haze, or dirty lens. Uses medium sensitivity — only removes clearly damaged images. Thresholds configurable in .env. ~26 min for 15K images. \n\n啟用 AI 雨滴/霧氣/水滴偵測（CLIP 模型）。移除有雨滴、霧氣、朦朧或鏡頭髒污的圖片。使用中等靈敏度 — 僅移除明顯受損的圖片。閾值可在 .env 中設定。15K 張圖片約 26 分鐘。",
            "default": false
          },
          "darkness_detection": {
            "type": "boolean",
            "title": "Darkness Detection",
            "description": "Auto-delete images that are too dark or too bright. Catches night shots, overexposed frames, and washed-out images. Thresholds (configurable in .env): brightness\u003C40=dark, \u003E220=bright, overexposed\u003E30%, underexposed\u003E30%. \n\n自動刪除過暗或過亮的圖片。捕捉夜間拍攝、過度曝光和褪色的圖片。閾值（可在 .env 設定）：亮度\u003C40=過暗，\u003E220=過亮，過度曝光\u003E30%，曝光不足\u003E30%。",
            "default": false
          },
          "image_recovery": {
            "type": "boolean",
            "title": "Image Recovery",
            "description": "Recover damaged images using AI temporal fusion instead of deleting them. Blends clean neighboring frames to reconstruct damaged areas. Requires rain_fog_detection or darkness_detection to be enabled. Adds ~5-15 min depending on damage rate. \n\n使用 AI 時序融合修復受損圖片，而非直接刪除。混合相鄰的乾淨幀來重建受損區域。需要啟用 rain_fog_detection 或 darkness_detection。根據損壞率增加約 5-15 分鐘。",
            "default": false
          },
          "stabilization": {
            "type": "boolean",
            "title": "Stabilization",
            "description": "Enable smooth video output via motion-compensated frame interpolation. Doubles frame rate (30→60fps) by synthesizing intermediate frames. Reduces the jittery/flickery look common in timelapses. Adds ~30-40 min for 4K video. \n\n透過動態補償影格插值啟用平滑影片輸出。將幀率加倍（30→60fps），合成中間影格。減少縮時影片常見的抖動/閃爍感。4K 影片額外增加約 30-40 分鐘。",
            "default": false
          }
        },
        "type": "object",
        "required": [
          "nas_path",
          "callback_url"
        ],
        "title": "NasJobCreateRequest",
        "description": "Create a timelapse video from images on the NAS.\n\n從 NAS 上的圖片建立縮時影片。\n\nProcessing options can be combined independently.\n處理選項可以獨立組合使用。\n\n---\n\n**Scenarios / 使用情境:**\n\n1. **Raw video / 原始影片** — No toggles, fastest (~10 min for 15K images).\n   不開啟任何選項，最快速（15K 張圖片約 10 分鐘）。\n\n2. **Filtered / 過濾影片** — Remove rain, fog, and dark images.\n   移除雨天、霧氣和過暗/過亮的圖片。\n\n3. **Enhanced / 增強影片** — Detect bad images + recover them via AI fusion.\n   偵測有問題的圖片，並透過 AI 融合技術修復。\n\n4. **Stabilized / 穩定影片** — All processing + smooth 60fps motion interpolation.\n   所有處理 + 平滑 60fps 動態補間。",
        "examples": [
